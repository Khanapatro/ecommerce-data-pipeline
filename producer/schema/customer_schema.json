{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Customer Event",
  "description": "Schema for ecommerce customer profile events produced to ecom.customers topic",
  "type": "object",
  "required": ["customer_id", "email", "first_name", "last_name", "event_time"],
  "properties": {
    "customer_id": {
      "type": "string",
      "description": "Unique customer identifier",
      "example": "CUST-000123"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Customer email address"
    },
    "first_name": { "type": "string" },
    "last_name":  { "type": "string" },
    "phone": {
      "type": ["string", "null"],
      "description": "Customer phone number"
    },
    "date_of_birth": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Customer date of birth (YYYY-MM-DD)"
    },
    "gender": {
      "type": ["string", "null"],
      "enum": ["M", "F", "Other", "Prefer not to say", null]
    },
    "address": {
      "type": "object",
      "properties": {
        "street":   { "type": "string" },
        "city":     { "type": "string" },
        "state":    { "type": "string" },
        "zip_code": { "type": "string" },
        "country":  { "type": "string" }
      }
    },
    "segment": {
      "type": "string",
      "description": "Customer value segment",
      "enum": ["bronze", "silver", "gold", "platinum"]
    },
    "signup_date": {
      "type": "string",
      "format": "date",
      "description": "Date customer signed up (YYYY-MM-DD)"
    },
    "is_active": {
      "type": "boolean",
      "description": "Whether the customer account is active"
    },
    "event_time": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of event"
    }
  }
}